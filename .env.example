# Copia este archivo a ".env" y completa con los datos de tu proyecto Supabase.
# Mientras estas variables no existan, la web funciona igual con datos mock/fallback locales.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dominio(s) de correo institucional permitido(s) para identificarse, separados por coma.
VITE_DOMINIOS_CORREO_PERMITIDOS=mail.udp.cl
